# ── Ignore everything, then allowlist ────────────────────────────────────────
*

# ── Top-level files ─────────────────────────────────────────────────────────
!.gitignore
!.python-version
!.env.example
!pyproject.toml
!uv.lock
!README.md

# ── Source code ─────────────────────────────────────────────────────────────
!src/
!src/**

# ── Tests ───────────────────────────────────────────────────────────────────
!tests/
!tests/**

# ── Config ──────────────────────────────────────────────────────────────────
!config/
!config/**

# ── Data (stories, baselines) ──────────────────────────────────────────────
!data/
!data/**

# ── Report (Typst source only) ─────────────────────────────────────────────
!docs/
!docs/report/
!docs/report/**

# ── Infrastructure ─────────────────────────────────────────────────────────
!infrastructure/
!infrastructure/**

# ── Always ignore (override allowlists) ────────────────────────────────────

# Build artifacts
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
build/

# Virtual environments
.venv/
venv/
env/

# Testing & linting
htmlcov/
.coverage
.coverage.*
.pytest_cache/
.ruff_cache/

# Node
node_modules/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
Desktop.ini
nul

# Generated files
*.pdf
*.png
# Allow report figures
!docs/report/figures/**/*.png
*.duckdb
*.duckdb.wal

# Secrets
.env
*.pem
*.key

# Nested project artifacts
data/baseline/uv.lock
data/baseline/docs/design/diagrams/

# Internal notes
docs/report/papers-to-add.md
