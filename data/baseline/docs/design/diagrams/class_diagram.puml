@startuml

class User {
  +UUID id
  +String username
  +String email
  +String password_hash
  +String role
}

class Project {
  +UUID id
  +String name
  +String description
  +UUID owner_id
}

class Issue {
  +UUID id
  +String title
  +String description
  +String status
  +String priority
  +UUID assignee_id
  +UUID project_id
}

class Comment {
  +UUID id
  +String content
  +UUID author_id
  +UUID issue_id
}

class Label {
  +UUID id
  +String name
}

class ActivityLog {
  +UUID id
  +UUID issue_id
  +String action
  +Timestamp timestamp
  +UUID user_id
}

User "1" -- "*" Project : owns
User "1" -- "*" Issue : assigned
Project "1" -- "*" Issue : contains
Issue "1" -- "*" Comment : has
Issue "*" -- "*" Label : tagged
Issue "1" -- "*" ActivityLog : logs

@enduml